# Copy to .env and adjust. All are optional; sensible defaults apply.

# Where raw/processed data lives (defaults to ./data)
DATA_DIR=./data

# Where trained models + indexes are written (defaults to ./models)
MODELS_DIR=./models

# MLflow tracking (defaults to local ./mlruns file store)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT=nlp-intelligence-system

# Reproducibility
SEED=42

# Kaggle credentials (or place ~/.kaggle/kaggle.json)
KAGGLE_USERNAME=
KAGGLE_KEY=
